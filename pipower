#!/usr/bin/env python3
"""
pipower - Raspberry Pi 5 RTC Scheduled Power Management CLI
===========================================================
Manages daily wake/sleep power cycles on the Raspberry Pi 5 using
its built-in PCF85063A real-time clock (RTC) and PMIC wake alarm.

Architecture Overview
---------------------
Three systemd units are installed to coordinate shutdown and wake:

  pipower-alarm.service
      Starts at boot (RemainAfterExit=yes) and stays "active" until
      the system shuts down. Its ExecStop runs `pipower _pre-shutdown`,
      which writes the next wake epoch to the RTC wakealarm sysfs file
      (/sys/class/rtc/rtc0/wakealarm) immediately before halt. This
      intercepts ALL shutdown paths — scheduled, manual, or emergency.

  pipower-shutdown.timer
      Fires at the configured sleep_time (OnCalendar, timezone-aware).
      Triggers pipower-shutdown.service.

  pipower-shutdown.service
      Calls `systemctl poweroff`, which triggers pipower-alarm.service
      ExecStop as part of the normal shutdown sequence.

Wake Mechanism
--------------
Writing a UTC epoch integer to /sys/class/rtc/rtc0/wakealarm programs
the Pi 5 PMIC to restore power at that time. The system must be halted
(not suspended) and external 5V power must remain present. The RTC
battery (J5 connector) maintains timekeeping only — it does not power
the board during halt.

Time Synchronization
--------------------
chrony disciplines the system clock against NRC stratum-2 atomic clock
servers (time.nrc.ca, time.chu.nrc.ca) and Cloudflare NTS. The
`rtcsync` chrony directive writes the NTP-corrected time back to the
hardware RTC every 11 minutes, ensuring wake alarm epochs are accurate.

Version: V2.0
Changelog:
  V2.3 - BUGFIX: Root cause of immediate shutdown identified and fixed.
         Removed `Requires=pipower-shutdown.service` from timer [Unit]
         section. systemd activates Requires= dependencies immediately
         when the unit starts — causing pipower-shutdown.service to run
         systemctl poweroff the instant `pipower enable` was called.
         Also removed redundant `Unit=` from [Timer] — systemd auto-links
         pipower-shutdown.timer to pipower-shutdown.service by name.
  V2.2 - BUGFIX: Removed OnBootSec=2min from timer unit. When OnBootSec
         and OnCalendar both appear in a systemd timer, they are OR'd —
         the timer fires on whichever condition is met first. This caused
         immediate shutdown when enable was run on an already-booted system.
         OnCalendar alone with Persistent=false is the correct approach.
  V2.1 - BUGFIX: cmd_install legacy config migration and install safety
         gate upversioned to V2.1. No functional change from V2.0 fix —
         version bump to align script with documentation suite.
  V2.0 - Version alignment with documentation suite. BUGFIX: cmd_install
         now migrates legacy configs missing tested/test_epoch fields, and
         enforces the test gate on install — never re-enables the shutdown
         timer if tested=False, even if preserved config has enabled=True.
         Prevents shutdown loop on reinstall over a pre-V2.0 config.
  V1.9 - Added test-gate safety requirement. `pipower enable` now refuses
         to activate unless the full halt→wake test cycle has been completed
         successfully at least once. Mechanism:
         - `test-alarm --halt` stores test_epoch in config before halting.
         - On next boot, pipower-alarm.service ExecStart runs `pipower
           _post-boot`, which checks whether boot time matches test_epoch
           (within a 5-minute tolerance). On match, sets tested=True and
           clears test_epoch.
         - `pipower enable` checks tested=True; refuses with instructions
           if not set.
         - `pipower status` shows test status.
         - `pipower reset-test` clears the tested flag (for re-testing).
         - alarm_service_content() updated: ExecStart now calls
           `pipower _post-boot` instead of /bin/true.
  V1.8 - BUGFIX: Timer firing immediately — removed timezone from
         OnCalendar, added OnBootSec=2min guard.
  V1.6 - Added global --verbose (-v) and --debug (-d) flags.
  V1.5 - Updated chrony NTP sources: NRC stratum-2 servers added.
  V1.4 - Reverted install location to /usr/local/bin/pipower.
  V1.1 - (setup guide / architecture only — script unchanged from V1.0)
  V1.0 - Initial release.
"""

import argparse
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo, ZoneInfoNotFoundError

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

VERSION      = "V2.3"

# Script install location — /usr/local/bin is correct per FHS for locally-
# administered tools that depend on system components (Python, systemd).
INSTALL_BIN  = Path("/usr/local/bin/pipower")

# Configuration directory and file — /etc is correct for host-specific
# runtime configuration of a locally-installed tool.
CONFIG_DIR   = Path("/etc/pipower")
CONFIG_FILE  = CONFIG_DIR / "config.json"

# Linux kernel sysfs interface to the Pi 5 PCF85063A RTC wake alarm.
# Writing a UTC epoch integer here programs the PMIC to restore power
# at that time after a halt. Must be cleared (write "0") before writing
# a new value — the kernel driver requires this two-step sequence.
WAKEALARM_PATH = Path("/sys/class/rtc/rtc0/wakealarm")

# systemd unit directory — all three pipower units live here.
SYSTEMD_DIR  = Path("/etc/systemd/system")

# Systemd unit names — defined as constants so any rename is a single change.
ALARM_SVC_NAME    = "pipower-alarm.service"    # alarm guard — always active
SHUTDOWN_SVC_NAME = "pipower-shutdown.service" # triggered by timer
SHUTDOWN_TIMER_NAME = "pipower-shutdown.timer" # fires at sleep_time

# Derived unit file paths.
ALARM_SVC_PATH    = SYSTEMD_DIR / ALARM_SVC_NAME
SHUTDOWN_SVC_PATH = SYSTEMD_DIR / SHUTDOWN_SVC_NAME
SHUTDOWN_TIMER_PATH = SYSTEMD_DIR / SHUTDOWN_TIMER_NAME

# Tolerance in seconds for matching boot time against the expected test
# wake epoch. Accounts for PMIC startup time, fsck delays, and systemd
# service ordering jitter. 5 minutes is generous but safe.
TEST_WAKE_TOLERANCE_SECS = 300

# Default configuration written on first install. The user must run
# `pipower set`, complete `pipower test-alarm --halt`, and then run
# `pipower enable` before the schedule becomes active.
DEFAULT_CONFIG = {
    "_version":     VERSION,
    "_description": "pipower configuration - edit with: sudo pipower set --wake HH:MM --sleep HH:MM",
    "wake_time":    "06:30",           # HH:MM local time to power on
    "sleep_time":   "22:00",           # HH:MM local time to power off
    "enabled":      False,             # must be explicitly enabled after review
    "timezone":     "America/Toronto", # IANA timezone name
    "tested":       False,             # True after a successful test-alarm --halt cycle
    "test_epoch":   None,              # epoch stored before test halt; cleared on confirmed wake
}


# ---------------------------------------------------------------------------
# Logger
# ---------------------------------------------------------------------------

class Logger:
    """
    Module-level output controller for --verbose and --debug modes.

    Two output levels are supported:

      verbose  Step-by-step progress messages showing what the command is
               doing at a high level (e.g. "Writing systemd unit files").
               Prefixed with '→'. Activated by --verbose or --debug.

      debug    Low-level implementation detail including variable values,
               sysfs read/write operations, subprocess command lines, and
               raw config content. Prefixed with '[DEBUG]'. Activated by
               --debug only. --debug implies --verbose automatically.

    Both levels write to stdout (not stderr) so output can be captured
    in pipelines or log files. All output is immediately flushed to ensure
    correct ordering when interleaved with subprocess output.

    The single module-level instance `LOG` is configured once in main()
    after argument parsing, then used throughout all helper functions and
    command implementations without needing to pass it as a parameter.
    """

    def __init__(self):
        """Initialise with both output levels disabled."""
        self.verbose_on = False
        self.debug_on   = False

    def configure(self, verbose: bool, debug: bool):
        """
        Activate output levels based on parsed CLI flags.

        Called once from main() after argparse completes. --debug
        automatically enables verbose as well, so callers never need
        to pass both flags.

        Args:
            verbose: True if --verbose / -v was supplied on the CLI.
            debug:   True if --debug / -d was supplied on the CLI.
        """
        self.verbose_on = verbose or debug   # debug implies verbose
        self.debug_on   = debug

    def step(self, msg: str):
        """
        Emit a verbose-level step message if verbose mode is active.

        Used to narrate high-level command progress: what is about to
        happen, not implementation details. Output is prefixed with '→'
        to visually distinguish it from normal command output.

        Args:
            msg: Human-readable description of the current step.
        """
        if self.verbose_on:
            print(f"  → {msg}", flush=True)

    def debug(self, msg: str):
        """
        Emit a debug-level message if debug mode is active.

        Used for low-level implementation detail: variable values,
        sysfs read/write content, subprocess arguments, config dumps.
        Output is prefixed with '[DEBUG]'.

        Args:
            msg: Debug detail string. May be multi-line.
        """
        if self.debug_on:
            print(f"  [DEBUG] {msg}", flush=True)

    def warn(self, msg: str):
        """
        Emit a warning message unconditionally (not gated on any flag).

        Used for non-fatal conditions that the user should always see
        regardless of verbosity level.

        Args:
            msg: Warning message to display.
        """
        print(f"  [WARN]  {msg}", flush=True)


LOG = Logger()


